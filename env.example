# ============================================================
# FILE: .env.example
# Environment variables untuk SIG EV Station Medan Backend
# Hikmal Akbar | 2305181024 | Teknologi Rekayasa Perangkat Lunak
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai
# ============================================================

# ── NODE ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── DATABASE PostgreSQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sig_ev_medan
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ── JWT ─────────────────────────────────────────────────────
# Ganti dengan string acak yang panjang dan kuat!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_secret_key_yang_sangat_panjang_dan_acak_minimal_64_karakter
JWT_EXPIRES_IN=7d

# ── GOOGLE OAUTH ─────────────────────────────────────────────
# Dapatkan dari: https://console.cloud.google.com/
# 1. Buat project baru
# 2. APIs & Services > Credentials > Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:5500, http://127.0.0.1:5500
# 5. Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── CLOUDINARY ───────────────────────────────────────────────
# Dapatkan dari: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── FRONTEND ─────────────────────────────────────────────────
# URL frontend untuk CORS whitelist
FRONTEND_URL=http://127.0.0.1:5500
